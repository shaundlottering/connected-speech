---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  keywords: string;
  path: string;
  ogTitle?: string;
  ogDescription?: string;
}

const { title, description, keywords, path, ogTitle, ogDescription } = Astro.props;
const canonical = `https://connectedspeech.co.za${path}`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content={keywords} />
  <link rel="canonical" href={canonical} />

  <!-- Favicons -->
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#9654C7" />
  <link rel="llms" href="/llms.txt" />

  <!-- Open Graph -->
  <meta property="og:site_name" content="Connected Speech" />
  <meta property="og:title" content={ogTitle ?? title} />
  <meta property="og:description" content={ogDescription ?? description} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content="https://connectedspeech.co.za/connected-speech-logo-transparent.png" />
  <meta property="og:image:width" content="1024" />
  <meta property="og:image:height" content="380" />
  <meta property="og:image:type" content="image/png" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={ogTitle ?? title} />
  <meta name="twitter:description" content={ogDescription ?? description} />
  <meta name="twitter:image" content="https://connectedspeech.co.za/connected-speech-logo-transparent.png" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,500&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <!-- Structured Data -->
  <script type="application/ld+json" is:inline>
  {
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": ["LocalBusiness", "MedicalBusiness"],
        "@id": "https://connectedspeech.co.za/#business",
        "name": "Connected Speech",
        "description": "Specialist speech therapy practice in Sandton, Johannesburg. We support children and adults with language delays, stuttering, feeding therapy, complex communication needs, and adults recovering from strokes and other medical conditions, using AAC, Makaton, and PROMPT.",
        "url": "https://connectedspeech.co.za",
        "logo": "https://connectedspeech.co.za/connected-speech-logo-transparent.png",
        "image": "https://connectedspeech.co.za/connected-speech-logo-transparent.png",
        "email": "jodi@connectedspeech.co.za",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Sandton",
          "addressRegion": "Gauteng",
          "addressCountry": "ZA"
        },
        "areaServed": [
          { "@type": "City", "name": "Sandton" },
          { "@type": "City", "name": "Johannesburg" }
        ],
        "openingHoursSpecification": [
          {
            "@type": "OpeningHoursSpecification",
            "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday"]
          }
        ],
        "paymentAccepted": "Medical Aid",
        "founder": { "@id": "https://connectedspeech.co.za/#jodi" },
        "employee": { "@id": "https://connectedspeech.co.za/#jodi" },
        "hasOfferCatalog": {
          "@type": "OfferCatalog",
          "name": "Speech Therapy Services",
          "itemListElement": [
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Language Delay Therapy",
                "description": "Early intervention for children not hitting language milestones."
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Language and Literacy Development Therapy",
                "description": "Building vocabulary, sentence structure, and phonological awareness to support reading and writing skills."
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Articulation and Intelligibility Therapy",
                "description": "Therapy to improve accurate sound production and clear speech patterns, improving intelligibility."
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Stuttering Therapy",
                "description": "Fluency therapy for children and adults who stutter, building confidence and communication skills."
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Feeding Therapy",
                "description": "Support for children with texture aversions, swallowing difficulties, or oral motor challenges."
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Complex Communication Needs / AAC Therapy",
                "description": "Augmentative and Alternative Communication support using Makaton, PROMPT, and high-tech devices for children and adults."
              }
            },
            {
              "@type": "Offer",
              "itemOffered": {
                "@type": "Service",
                "name": "Stroke and Medical Condition Related Communication Therapy",
                "description": "Communication therapy for adults recovering from strokes and other medical conditions that affect communication."
              }
            }
          ]
        },
        "sameAs": ["https://www.linkedin.com/company/connectedspeech/"]
      },
      {
        "@type": "Person",
        "@id": "https://connectedspeech.co.za/#jodi",
        "name": "Jodi Zimmerman",
        "jobTitle": "Speech-Language Pathologist",
        "description": "Specialist in Augmentative and Alternative Communication with 8 years of clinical experience in speech therapy.",
        "worksFor": { "@id": "https://connectedspeech.co.za/#business" },
        "alumniOf": [
          {
            "@type": "EducationalOrganization",
            "name": "University of Cape Town",
            "description": "BSc Speech-Language Pathology, 2016"
          },
          {
            "@type": "EducationalOrganization",
            "name": "University of Pretoria",
            "description": "MSc Augmentative and Alternative Communication, 2022"
          }
        ],
        "hasCredential": [
          {
            "@type": "EducationalOccupationalCredential",
            "credentialCategory": "degree",
            "name": "BSc Speech-Language Pathology",
            "recognizedBy": { "@type": "EducationalOrganization", "name": "University of Cape Town" }
          },
          {
            "@type": "EducationalOccupationalCredential",
            "credentialCategory": "degree",
            "name": "MSc Augmentative and Alternative Communication",
            "recognizedBy": { "@type": "EducationalOrganization", "name": "University of Pretoria" }
          }
        ],
        "sameAs": ["https://www.linkedin.com/in/jodi-zimmerman-135601173/"]
      },
      {
        "@type": "WebSite",
        "@id": "https://connectedspeech.co.za/#website",
        "url": "https://connectedspeech.co.za",
        "name": "Connected Speech",
        "description": "Specialist speech therapy in Sandton, Johannesburg for children and adults with language delays, stuttering, feeding therapy, and complex communication needs.",
        "publisher": { "@id": "https://connectedspeech.co.za/#business" },
        "inLanguage": "en-ZA"
      }
    ]
  }
  </script>

  <style is:global>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --purple:       #9654C7;
      --purple-mid:   #7B3DAE;
      --purple-light: #F3ECFB;
      --purple-pale:  #FAF5FF;
      --ink:          #1A1A2E;
      --body:         #4A4A5A;
      --white:        #FFFFFF;
      --border:       #E8DCF5;
      --font-display: 'Cormorant Garamond', Georgia, serif;
      --font-body:    'Jost', system-ui, sans-serif;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: var(--font-body);
      color: var(--body);
      background: var(--white);
      -webkit-font-smoothing: antialiased;
    }

    img { max-width: 100%; display: block; }
    a { color: inherit; text-decoration: none; }

    /* Nav */
    .nav {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(255,255,255,0.95);
      backdrop-filter: blur(8px);
      border-bottom: 1px solid var(--border);
      padding: 0 2rem;
    }

    .nav-inner {
      max-width: 1160px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 72px;
    }

    .nav-logo img { height: 48px; width: auto; }

    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
      align-items: center;
    }

    .nav-links a {
      font-size: 0.9rem;
      font-weight: 500;
      color: var(--body);
      transition: color 0.2s;
    }

    .nav-links a:hover,
    .nav-links a[aria-current="page"] { color: var(--purple); }

    .nav-cta {
      background: var(--purple);
      color: var(--white) !important;
      padding: 0.55rem 1.25rem;
      border-radius: 100px;
      font-weight: 600;
      font-size: 0.875rem;
      transition: background 0.2s;
    }

    .nav-cta:hover { background: var(--purple-mid) !important; }

    .nav-toggle {
      display: none;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      background: none;
      border: none;
      border-radius: 50%;
      padding: 0;
      cursor: pointer;
      transition: background 0.2s ease;
    }

    .nav-toggle:hover,
    .nav-toggle:focus-visible {
      background: var(--purple-light);
      outline: none;
    }

    .nav-toggle-bars {
      position: relative;
      width: 20px;
      height: 13px;
    }

    .nav-toggle-bar {
      position: absolute;
      left: 0;
      width: 100%;
      height: 2px;
      background: var(--ink);
      border-radius: 2px;
      transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.2s ease, background 0.2s ease;
    }

    .nav-toggle-bar:nth-child(1) { top: 0; }
    .nav-toggle-bar:nth-child(2) { top: 50%; transform: translateY(-50%); }
    .nav-toggle-bar:nth-child(3) { bottom: 0; }

    .nav-toggle.is-open .nav-toggle-bar { background: var(--purple); }
    .nav-toggle.is-open .nav-toggle-bar:nth-child(1) { top: 50%; transform: translateY(-50%) rotate(45deg); }
    .nav-toggle.is-open .nav-toggle-bar:nth-child(2) { opacity: 0; }
    .nav-toggle.is-open .nav-toggle-bar:nth-child(3) { bottom: 50%; transform: translateY(50%) rotate(-45deg); }

    /* Hero */
    .hero {
      max-width: 1160px;
      margin: 0 auto;
      padding: 6rem 2rem 5rem;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }

    .hero-text { max-width: 560px; }

    .hero-eyebrow {
      display: inline-block;
      font-size: 0.8rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--purple);
      margin-bottom: 1.25rem;
    }

    .hero-headline {
      font-family: var(--font-display);
      font-size: clamp(2.4rem, 4.5vw, 3.5rem);
      line-height: 1.15;
      color: var(--ink);
      margin-bottom: 1.75rem;
    }

    .hero-headline .underline-word {
      position: relative;
      display: inline;
      white-space: nowrap;
    }

    .hero-headline .underline-word::after {
      content: '';
      position: absolute;
      left: 0;
      bottom: -4px;
      height: 4px;
      width: 0;
      background: var(--purple);
      border-radius: 2px;
      animation: drawLine 0.9s ease forwards 0.6s;
    }

    @keyframes drawLine { to { width: 100%; } }

    .hero-sub {
      font-size: 1.1rem;
      line-height: 1.75;
      color: var(--body);
      margin-bottom: 2.25rem;
    }

    .hero-sub strong { color: var(--ink); font-weight: 600; }

    .hero-actions {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
      align-items: center;
    }

    .btn-primary {
      background: var(--purple);
      color: var(--white);
      padding: 0.85rem 2rem;
      border-radius: 100px;
      font-weight: 600;
      font-size: 0.95rem;
      transition: background 0.2s, transform 0.15s;
      display: inline-block;
    }

    .btn-primary:hover { background: var(--purple-mid); transform: translateY(-1px); }

    .btn-ghost {
      color: var(--purple);
      font-weight: 600;
      font-size: 0.95rem;
      padding: 0.85rem 0;
      border-bottom: 2px solid var(--purple);
      transition: color 0.2s, border-color 0.2s;
    }

    .btn-ghost:hover { color: var(--purple-mid); border-color: var(--purple-mid); }

    .hero-visual { display: flex; justify-content: center; align-items: center; }

    .hero-logo-card {
      background: var(--purple-light);
      border-radius: 2rem;
      padding: 3.5rem;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 1.5rem;
      width: 100%;
      max-width: 400px;
    }

    .hero-logo-card img { width: 180px; height: auto; }

    .hero-logo-tagline {
      font-family: var(--font-display);
      font-style: italic;
      font-size: 1.05rem;
      color: var(--purple-mid);
      text-align: center;
      line-height: 1.6;
    }

    /* Mission Bar */
    .mission-bar {
      background: var(--purple);
      padding: 3rem 2rem;
      text-align: center;
    }

    .mission-bar p {
      font-family: var(--font-display);
      font-size: clamp(1.4rem, 3vw, 2rem);
      color: var(--white);
      max-width: 720px;
      margin: 0 auto;
      line-height: 1.5;
    }

    /* Section Base */
    .section { padding: 5rem 2rem; }

    .section-inner { max-width: 1160px; margin: 0 auto; }

    .section-label {
      font-size: 0.78rem;
      font-weight: 600;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--purple);
      margin-bottom: 0.75rem;
      display: block;
    }

    .section-heading {
      font-family: var(--font-display);
      font-size: clamp(1.8rem, 3vw, 2.5rem);
      color: var(--ink);
      line-height: 1.25;
      margin-bottom: 1.5rem;
    }

    .section-body {
      font-size: 1.05rem;
      line-height: 1.85;
      color: var(--body);
    }

    .section-body p + p { margin-top: 1.25rem; }

    /* About Connected Speech */
    .about-cs { background: var(--white); }

    .about-cs-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
      align-items: center;
    }

    .about-cs-visual {
      background: var(--purple-light);
      border-radius: 1.5rem;
      padding: 3rem;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 320px;
    }

    .about-cs-visual img { width: 200px; height: auto; opacity: 0.9; }

    .values-list {
      margin-top: 2rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .value-item { display: flex; gap: 1rem; align-items: flex-start; }

    .value-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: var(--purple);
      margin-top: 7px;
      flex-shrink: 0;
    }

    .value-item p { font-size: 1rem; line-height: 1.65; color: var(--body); }

    /* About Jodi */
    .about-jodi { background: var(--purple-pale); }

    .about-jodi-grid { max-width: 720px; }

    .jodi-credentials {
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      margin-top: 2rem;
      padding-top: 2rem;
      border-top: 1px solid var(--border);
    }

    .credential {
      display: flex;
      gap: 0.75rem;
      align-items: flex-start;
      font-size: 0.9rem;
      color: var(--body);
      line-height: 1.5;
    }

    .credential-icon { color: var(--purple); font-size: 1rem; margin-top: 1px; flex-shrink: 0; }

    /* What We Work On / Services */
    .conditions { background: var(--white); }

    .conditions-intro { max-width: 600px; margin-bottom: 3rem; }

    .service-group { margin-bottom: 3.5rem; }
    .service-group:last-child { margin-bottom: 0; }

    .service-group-heading {
      font-family: var(--font-display);
      font-size: 1.4rem;
      color: var(--purple-mid);
      margin-bottom: 1.5rem;
    }

    .conditions-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }

    .condition-card {
      background: var(--purple-pale);
      border: 1px solid var(--border);
      border-radius: 1.25rem;
      padding: 2rem 2rem 2rem;
      transition: box-shadow 0.2s, transform 0.2s;
    }

    .condition-card:hover {
      box-shadow: 0 8px 32px rgba(150, 84, 199, 0.12);
      transform: translateY(-2px);
    }

    .condition-icon { font-size: 2rem; margin-bottom: 1rem; display: block; }

    .condition-title {
      font-family: var(--font-display);
      font-size: 1.3rem;
      color: var(--ink);
      margin-bottom: 0.75rem;
    }

    .condition-desc { font-size: 0.95rem; line-height: 1.7; color: var(--body); }

    /* CTA Section */
    .cta-section {
      background: var(--purple);
      padding: 5rem 2rem;
      text-align: center;
    }

    .cta-section h1,
    .cta-section h2 {
      font-family: var(--font-display);
      font-size: clamp(1.8rem, 3vw, 2.5rem);
      color: var(--white);
      margin-bottom: 1rem;
      line-height: 1.3;
    }

    .cta-section p {
      color: rgba(255,255,255,0.85);
      font-size: 1.05rem;
      line-height: 1.75;
      max-width: 520px;
      margin: 0 auto 2.25rem;
    }

    .btn-white {
      background: var(--white);
      color: var(--purple);
      padding: 0.9rem 2.25rem;
      border-radius: 100px;
      font-weight: 700;
      font-size: 1rem;
      display: inline-block;
      transition: transform 0.15s, box-shadow 0.2s;
      margin-bottom: 1.5rem;
    }

    .btn-white:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.15); }

    .cta-note { margin-top: 1.25rem; font-size: 0.85rem; color: rgba(255,255,255,0.65); }

    /* Contact details */
    .contact-details {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      max-width: 480px;
      margin: 0 auto 2.25rem;
      text-align: left;
    }

    .contact-details .credential { color: rgba(255,255,255,0.9); font-size: 1rem; }
    .contact-details .credential-icon { color: var(--white); }

    /* Services at a Glance (Home) */
    .services-glance-list {
      list-style: none;
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      margin: 2rem 0 2.5rem;
    }

    .services-glance-item {
      display: flex;
      align-items: flex-start;
      gap: 0.6rem;
      background: var(--purple-pale);
      border: 1px solid var(--border);
      border-radius: 14px;
      padding: 0.9rem 1.1rem;
      font-size: 0.92rem;
      font-weight: 500;
      line-height: 1.4;
      color: var(--ink);
      flex: 0 1 200px;
      min-width: 170px;
      max-width: 220px;
    }

    .services-glance-icon { font-size: 1.1rem; }

    /* Footer */
    .footer { background: var(--ink); padding: 3rem 2rem; }

    .footer-inner {
      max-width: 1160px;
      margin: 0 auto;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 2rem;
      flex-wrap: wrap;
    }

    .footer-logo img { height: 36px; width: auto; filter: brightness(0) invert(1); opacity: 0.85; }

    .footer-tagline { font-family: var(--font-display); font-style: italic; font-size: 0.95rem; color: rgba(255,255,255,0.55); }

    .footer-right { display: flex; flex-direction: column; align-items: flex-end; gap: 0.5rem; }

    .footer-linkedin { color: rgba(255,255,255,0.45); transition: color 0.2s; }
    .footer-linkedin:hover { color: rgba(255,255,255,0.9); }

    .footer-copy { font-size: 0.8rem; color: rgba(255,255,255,0.35); }

    /* Responsive */
    @media (max-width: 900px) {
      .hero { grid-template-columns: 1fr; padding: 4rem 1.5rem 3rem; gap: 2.5rem; }
      .hero-visual { order: -1; }
      .hero-logo-card { max-width: 100%; padding: 2.5rem; }
      .about-cs-grid { grid-template-columns: 1fr; gap: 2.5rem; }
      .conditions-grid { grid-template-columns: 1fr; }
      .section { padding: 3.5rem 1.5rem; }

      .nav-toggle { display: flex; }

      .nav-links {
        position: absolute;
        top: 72px;
        left: 0;
        right: 0;
        flex-direction: column;
        align-items: flex-start;
        gap: 1.1rem;
        background: rgba(255,255,255,0.98);
        backdrop-filter: blur(8px);
        border-bottom: 1px solid var(--border);
        border-radius: 0 0 1.25rem 1.25rem;
        box-shadow: 0 16px 32px rgba(26, 26, 46, 0.08);
        padding: 1.5rem 2rem 1.75rem;
        transform: translateY(-10px);
        opacity: 0;
        pointer-events: none;
        transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.2s ease;
      }

      .nav-links.is-open {
        transform: translateY(0);
        opacity: 1;
        pointer-events: auto;
      }

      .nav-links li {
        width: 100%;
        opacity: 0;
        transform: translateY(-6px);
        transition: opacity 0.25s ease, transform 0.25s ease;
      }

      .nav-links.is-open li {
        opacity: 1;
        transform: translateY(0);
      }

      .nav-links.is-open li:nth-child(1) { transition-delay: 0.04s; }
      .nav-links.is-open li:nth-child(2) { transition-delay: 0.08s; }
      .nav-links.is-open li:nth-child(3) { transition-delay: 0.12s; }
      .nav-links.is-open li:nth-child(4) { transition-delay: 0.16s; }

      .nav-links a { display: inline-block; }
    }

    @media (max-width: 600px) {
      .hero-headline { font-size: 2.1rem; }
    }

    @media (prefers-reduced-motion: reduce) {
      .hero-headline .underline-word::after { animation: none; width: 100%; }
    }
  </style>

