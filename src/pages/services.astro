---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Speech Therapy Services Sandton | Connected Speech"
  description="Speech therapy services in Sandton for children and adults — language delay therapy, stuttering therapy, feeding therapy, AAC support, and communication therapy for adults recovering from strokes and other medical conditions."
  keywords="speech therapy services Sandton, stuttering therapy Sandton, AAC therapy Sandton, language delay therapy Sandton, feeding therapy children Sandton, adult speech therapy Sandton, complex communication needs Sandton, stroke speech therapy Sandton, stroke rehabilitation Sandton"
  path="/services"
  ogTitle="Speech Therapy Services | Connected Speech Sandton"
  ogDescription="Speech therapy services in Sandton for children and adults — language delay therapy, stuttering therapy, feeding therapy, AAC support, and communication therapy after stroke or medical conditions."
>
  <!-- What We Work On -->
  <section class="section conditions" aria-labelledby="conditions-heading">
    <div class="section-inner">
      <div class="conditions-intro">
        <span class="section-label">What We Work On</span>
        <h1 class="section-heading" id="conditions-heading">Support for the communication challenges that affect everyday life.</h1>
        <p class="section-body">
          We work with children from birth through to school age, and with adults navigating communication
          challenges at any stage of life. Every person receives a therapy plan built specifically for them.
        </p>
      </div>

      <div class="conditions-grid" role="list">
        <article class="condition-card" role="listitem">
          <span class="condition-icon" aria-hidden="true">💬</span>
          <h3 class="condition-title">Language Delays</h3>
          <p class="condition-desc">
            When language milestones are not being met, early intervention makes the biggest difference.
            We identify what is holding a child back and build the specific skills they need — so they can
            communicate their needs, connect with others, and thrive at school.
          </p>
        </article>
        <article class="condition-card" role="listitem">
          <span class="condition-icon" aria-hidden="true">🍽️</span>
          <h3 class="condition-title">Feeding Therapy</h3>
          <p class="condition-desc">
            Mealtimes should not be a source of stress. We work with children who have difficulty with
            textures, swallowing, or oral motor skills — helping them eat more comfortably and confidently,
            so that mealtimes become easier for the whole family.
          </p>
        </article>
        <article class="condition-card" role="listitem">
          <span class="condition-icon" aria-hidden="true">🗣️</span>
          <h3 class="condition-title">Stuttering</h3>
          <p class="condition-desc">
            Stuttering affects both children and adults, and the impact goes far beyond speech. We work
            with individuals and their families to build fluency, confidence, and the tools to communicate
            without fear — at any age.
          </p>
        </article>
        <article class="condition-card" role="listitem">
          <span class="condition-icon" aria-hidden="true">🤝</span>
          <h3 class="condition-title">Complex Communication Needs</h3>
          <p class="condition-desc">
            Some people communicate in ways that go beyond speech — and that is okay. We support children
            and adults with AAC tools, Makaton, PROMPT, and individualised strategies, so they can express
            themselves and participate fully in the world around them.
          </p>
        </article>
        <article class="condition-card" role="listitem">
          <span class="condition-icon" aria-hidden="true">🧠</span>
          <h3 class="condition-title">Stroke &amp; Medical Conditions</h3>
          <p class="condition-desc">
            We support adults recovering from strokes and other medical conditions that affect communication,
            helping them rebuild the skills they need to express themselves and reconnect with the people in their lives.
          </p>
        </article>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section" aria-labelledby="services-cta-heading">
    <h2 id="services-cta-heading">You have something to say.<br/>Let's help you say it.</h2>
    <p>
      We work with families and individuals across Sandton, Johannesburg. Sessions are billed through
      medical aid — speak to us about availability and we will take it from there.
    </p>
    <a href="/contact" class="btn-white">Get in Touch</a>
    <p class="cta-note">Medical aid rates apply.</p>
  </section>
</Layout>
