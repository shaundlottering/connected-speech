---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Speech Therapist Sandton | Connected Speech"
  description="Connected Speech provides specialist speech therapy in Sandton for children and adults. We give people the ability to communicate their needs — with words, with signs, with whatever works for them."
  keywords="speech therapy Sandton, speech therapist Sandton, paediatric speech therapy, children speech delay Sandton, AAC therapy Sandton, autism communication therapy Sandton, stuttering therapy Sandton, feeding therapy children, adult speech therapy Sandton"
  path="/"
  ogTitle="Connected Speech | Speech Therapy Sandton"
  ogDescription="Everyone deserves to be heard. Every family deserves to be connected. Specialist speech therapy in Sandton, Johannesburg."
>
  <!-- Hero -->
  <section class="hero" aria-labelledby="hero-heading">
    <div class="hero-text">
      <span class="hero-eyebrow">Speech Therapy · Sandton</span>
      <h1 class="hero-headline" id="hero-heading">
        We give people the ability to <span class="underline-word">communicate their needs</span>.
      </h1>
      <p class="hero-sub">
        For some, that means a child saying <strong>"mom"</strong> or <strong>"dad"</strong> for the first time.
        For others, it means being understood at the dinner table, in the classroom, at work, or anywhere that matters.
        With words, with signs, with anything that works.
      </p>
      <div class="hero-actions">
        <a href="/contact" class="btn-primary">Book a Session</a>
        <a href="/about" class="btn-ghost">Learn more</a>
      </div>
    </div>
    <div class="hero-visual" aria-hidden="true">
      <div class="hero-logo-card">
        <img src="/connected-speech-logo-transparent.png" alt="Connected Speech" />
        <p class="hero-logo-tagline">The day your child communicates what they need, and gets it.</br>That's what we work towards.</p>
      </div>
    </div>
  </section>

  <!-- Mission Bar -->
  <div class="mission-bar" aria-label="Our mission">
    <p>Everyone deserves to be heard. Every family deserves to be connected.</p>
  </div>

  <!-- Services at a Glance -->
  <section class="section" aria-labelledby="services-glance-heading">
    <div class="section-inner">
      <span class="section-label">What We Work On</span>
      <h2 class="section-heading" id="services-glance-heading">Services at a Glance</h2>
      <ul class="services-glance-list">
        <li class="services-glance-item"><span class="services-glance-icon" aria-hidden="true">💬</span>Language Delays</li>
        <li class="services-glance-item"><span class="services-glance-icon" aria-hidden="true">🍽️</span>Feeding Therapy</li>
        <li class="services-glance-item"><span class="services-glance-icon" aria-hidden="true">🗣️</span>Stuttering</li>
        <li class="services-glance-item"><span class="services-glance-icon" aria-hidden="true">🤝</span>Complex Communication Needs</li>
        <li class="services-glance-item"><span class="services-glance-icon" aria-hidden="true">🧠</span>Stroke &amp; Medical Conditions</li>
      </ul>
      <a href="/services" class="btn-ghost">View all services →</a>
    </div>
  </section>

  <!-- Who We Are -->
  <section class="section about-cs" aria-labelledby="home-about-heading">
    <div class="section-inner">
      <div class="about-cs-grid">
        <div class="about-cs-text">
          <span class="section-label">Who We Are</span>
          <h2 class="section-heading" id="home-about-heading">Built on one belief — everyone thrives when communication is consistent.</h2>
          <div class="section-body">
            <p>
              Connected Speech is a Sandton based private speech therapy practice working with children and adults
              who face communication challenges. We work with those who stutter, with language delays,
              feeding therapy, and with complex communication needs.
            </p>
          </div>
          <div class="values-list" aria-label="Our values">
            <div class="value-item">
              <div class="value-dot" aria-hidden="true"></div>
              <p><strong>Person-centred.</strong> Every therapy plan is built around the individual — their needs, their pace, their world.</p>
            </div>
            <div class="value-item">
              <div class="value-dot" aria-hidden="true"></div>
              <p><strong>Inclusive by design.</strong> Communication takes many forms. We support all of them.</p>
            </div>
            <div class="value-item">
              <div class="value-dot" aria-hidden="true"></div>
              <p><strong>Family-first.</strong> Families are partners in therapy, not bystanders. We make sure you know exactly how to support your loved one between sessions.</p>
            </div>
            <div class="value-item">
              <div class="value-dot" aria-hidden="true"></div>
              <p><strong>Results you can see.</strong> Real progress, reported clearly, after every session.</p>
            </div>
          </div>
          <div class="hero-actions" style="margin-top: 2rem;">
            <a href="/about" class="btn-ghost">More about us</a>
          </div>
        </div>
        <div class="about-cs-visual" aria-hidden="true">
          <img src="/connected-speech-logo-transparent.png" alt="" />
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section" aria-labelledby="cta-heading">
    <h2 id="cta-heading">You have something to say.<br/>Let's help you say it.</h2>
    <p>
      We work with families and individuals across Sandton, Johannesburg. Sessions are billed through
      medical aid — speak to us about availability and we will take it from there.
    </p>
    <a href="/contact" class="btn-white">Get in Touch</a>
    <p class="cta-note">Medical aid rates apply.</p>
  </section>
</Layout>
