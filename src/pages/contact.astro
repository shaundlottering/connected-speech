---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact Us | Connected Speech Sandton"
  description="Get in touch with Connected Speech, a speech therapy practice in Sandton. Sessions are billed through medical aid."
  keywords="speech therapy Sandton, contact speech therapist Sandton, book speech therapy session Sandton, Connected Speech contact"
  path="/contact"
  ogTitle="Contact Connected Speech | Speech Therapy Sandton"
  ogDescription="Get in touch with Connected Speech, a speech therapy practice in Sandton. Sessions are billed through medical aid."
>
  <!-- CTA -->
  <section class="cta-section" aria-labelledby="contact-heading">
    <h1 id="contact-heading">You have something to say.<br/>Let's help you say it.</h1>
    <p>
      We work with families and individuals across Sandton, Johannesburg. Sessions are billed through
      medical aid — speak to us about availability and we will take it from there.
    </p>
    <div class="contact-details" aria-label="Contact details">
      <div class="credential">
        <span class="credential-icon" aria-hidden="true">✦</span>
        <span>jodi@connectedspeech.co.za</span>
      </div>
      <div class="credential">
        <span class="credential-icon" aria-hidden="true">✦</span>
        <span>Sandton, Johannesburg, South Africa</span>
      </div>
      <div class="credential">
        <span class="credential-icon" aria-hidden="true">✦</span>
        <span>Sessions available Monday to Thursday</span>
      </div>
      <div class="credential">
        <span class="credential-icon" aria-hidden="true">✦</span>
        <span>Medical aid rates apply</span>
      </div>
    </div>
    <a href="mailto:jodi@connectedspeech.co.za" class="btn-white">Get in Touch</a>
    <p class="cta-note">Medical aid rates apply.</p>
  </section>
</Layout>
